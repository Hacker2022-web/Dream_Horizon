rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // The one account allowed to edit the site. Must match the admin user
    // created in Firebase Authentication (email/password).
    function isAdmin() {
      return request.auth != null
        && request.auth.token.email == 'dreamhorizonconcepts@gmail.com';
    }

    // Portfolio projects — anyone can view, only the admin can change.
    match /projects/{projectId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Team members — anyone can view, only the admin can change.
    match /team/{memberId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Site content (all editable copy, contact details, theme) — public read,
    // admin write. Stored as a single document at site_config/main.
    match /site_config/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Everything else is denied by default.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
